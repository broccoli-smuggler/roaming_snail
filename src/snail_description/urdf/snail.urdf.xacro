<?xml version="1.0"?>
<robot name="snail" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ============================================================
       Geometry parameters
       ============================================================ -->
  <xacro:arg name="use_sim" default="true"/>
  <xacro:arg name="controllers_config" default="$(find snail_bringup)/config/controllers.yaml"/>

  <!-- Overall body -->
  <xacro:property name="body_length" value="2.0"/>
  <xacro:property name="body_width"  value="0.50"/>
  <xacro:property name="body_height" value="0.30"/>
  <xacro:property name="ground_clearance" value="0.10"/>
  <xacro:property name="body_mass" value="50.0"/>

  <!-- Axle placements (measured from front / rear of body) -->
  <xacro:property name="front_axle_offset" value="0.20"/>
  <xacro:property name="rear_axle_offset"  value="0.20"/>
  <xacro:property name="front_track"       value="0.60"/>  <!-- left-right distance between drive wheels -->

  <!-- Wheels -->
  <xacro:property name="front_wheel_radius" value="0.19"/>  <!-- 38 cm diameter -->
  <xacro:property name="front_wheel_width"  value="0.10"/>
  <xacro:property name="front_wheel_mass"   value="3.0"/>

  <xacro:property name="rear_wheel_radius"  value="0.09"/>  <!-- 18 cm diameter -->
  <xacro:property name="rear_wheel_width"   value="0.05"/>
  <xacro:property name="rear_wheel_mass"    value="1.5"/>

  <!-- Steering range (mechanical limits, refine after hardware bringup) -->
  <xacro:property name="steer_limit" value="${pi/4}"/>  <!-- ±45° -->

  <!-- ============================================================
       Derived
       ============================================================ -->
  <xacro:property name="front_axle_x" value="${ body_length/2 - front_axle_offset}"/>   <!--  +0.80 -->
  <xacro:property name="rear_axle_x"  value="${-body_length/2 + rear_axle_offset}"/>    <!--  -0.80 -->
  <xacro:property name="wheelbase"    value="${front_axle_x - rear_axle_x}"/>           <!--   1.60 -->

  <!-- ============================================================
       Materials
       ============================================================ -->
  <material name="snail_shell"><color rgba="0.85 0.65 0.30 1.0"/></material>
  <material name="snail_tyre"><color rgba="0.10 0.10 0.10 1.0"/></material>
  <material name="snail_steel"><color rgba="0.55 0.55 0.60 1.0"/></material>

  <!-- ============================================================
       Inertia helpers
       ============================================================ -->
  <xacro:macro name="box_inertia" params="m x y z">
    <inertia ixx="${(1.0/12.0)*m*(y*y + z*z)}" ixy="0" ixz="0"
             iyy="${(1.0/12.0)*m*(x*x + z*z)}" iyz="0"
             izz="${(1.0/12.0)*m*(x*x + y*y)}"/>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="m r l">
    <!-- Cylinder oriented along Y after a rpy="pi/2 0 0" rotation (wheel axis = body Y). -->
    <inertia ixx="${(1.0/12.0)*m*(3*r*r + l*l)}" ixy="0" ixz="0"
             iyy="${(1.0/2.0)*m*r*r}"             iyz="0"
             izz="${(1.0/12.0)*m*(3*r*r + l*l)}"/>
  </xacro:macro>

  <!-- ============================================================
       Wheel macro
       ============================================================ -->
  <xacro:macro name="wheel_link" params="name radius width mass">
    <link name="${name}">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="${radius}" length="${width}"/></geometry>
        <material name="snail_tyre"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="${radius}" length="${width}"/></geometry>
      </collision>
      <inertial>
        <mass value="${mass}"/>
        <xacro:cylinder_inertia m="${mass}" r="${radius}" l="${width}"/>
      </inertial>
    </link>
  </xacro:macro>

  <!-- ============================================================
       Links
       ============================================================ -->
  <link name="base_link"/>

  <link name="chassis_link">
    <visual>
      <origin xyz="0 0 ${ground_clearance + body_height/2}" rpy="0 0 0"/>
      <geometry><box size="${body_length} ${body_width} ${body_height}"/></geometry>
      <material name="snail_shell"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${ground_clearance + body_height/2}" rpy="0 0 0"/>
      <geometry><box size="${body_length} ${body_width} ${body_height}"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 ${ground_clearance + body_height/2}"/>
      <mass value="${body_mass}"/>
      <xacro:box_inertia m="${body_mass}" x="${body_length}" y="${body_width}" z="${body_height}"/>
    </inertial>
  </link>

  <joint name="base_to_chassis" type="fixed">
    <parent link="base_link"/>
    <child  link="chassis_link"/>
    <origin xyz="0 0 0"/>
  </joint>

  <!-- Front drive wheels (2× — broadcast on hardware, both driven in sim) -->
  <xacro:wheel_link name="front_left_wheel_link"
                    radius="${front_wheel_radius}"
                    width="${front_wheel_width}"
                    mass="${front_wheel_mass}"/>
  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="chassis_link"/>
    <child  link="front_left_wheel_link"/>
    <origin xyz="${front_axle_x} ${ front_track/2} ${front_wheel_radius}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.05" friction="0.0"/>
  </joint>

  <xacro:wheel_link name="front_right_wheel_link"
                    radius="${front_wheel_radius}"
                    width="${front_wheel_width}"
                    mass="${front_wheel_mass}"/>
  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="chassis_link"/>
    <child  link="front_right_wheel_link"/>
    <origin xyz="${front_axle_x} ${-front_track/2} ${front_wheel_radius}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.05" friction="0.0"/>
  </joint>

  <!-- Rear steering column (the bit that rotates about Z when commanded) -->
  <link name="rear_steer_link">
    <visual>
      <origin xyz="0 0 ${-(ground_clearance - rear_wheel_radius)/2}"/>
      <geometry><cylinder radius="0.02" length="${ground_clearance - rear_wheel_radius}"/></geometry>
      <material name="snail_steel"/>
    </visual>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="rear_steer_joint" type="revolute">
    <parent link="chassis_link"/>
    <child  link="rear_steer_link"/>
    <origin xyz="${rear_axle_x} 0 ${ground_clearance}" rpy="0 0 0"/>
    <!-- Axis inverted (0 0 -1) so that positive joint angle matches positive
         angular.z from the front-steer-assuming tricycle_steering_controller.
         The deprecated front_steering:=false param used to handle this; we do
         it geometrically instead. -->
    <axis xyz="0 0 -1"/>
    <limit lower="${-steer_limit}" upper="${steer_limit}" effort="40.0" velocity="2.0"/>
    <dynamics damping="0.5" friction="0.0"/>
  </joint>

  <!-- Rear wheel (free-spinning, attached to the steering column) -->
  <xacro:wheel_link name="rear_wheel_link"
                    radius="${rear_wheel_radius}"
                    width="${rear_wheel_width}"
                    mass="${rear_wheel_mass}"/>
  <joint name="rear_wheel_joint" type="continuous">
    <parent link="rear_steer_link"/>
    <child  link="rear_wheel_link"/>
    <origin xyz="0 0 ${-(ground_clearance - rear_wheel_radius)}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.05" friction="0.0"/>
  </joint>

  <!-- ============================================================
       ros2_control + Gazebo
       ============================================================ -->
  <xacro:include filename="snail.ros2_control.xacro"/>
  <xacro:include filename="snail.gazebo.xacro"/>

</robot>
